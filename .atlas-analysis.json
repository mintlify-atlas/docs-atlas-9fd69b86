  "keyFeatures": [
    "Subscribe to YouTube channels and auto-download new videos",
    "Download videos using yt-dlp with configurable quality/format settings",
    "Full-text search powered by Elasticsearch across videos, channels, and subtitles",
    "Scheduled downloads and background task management via Celery",
    "SponsorBlock integration to skip sponsored segments",
    "Comment and subtitle indexing for searchable content",
    "User-created and YouTube playlists with full management",
    "Statistics dashboard with watch progress and download history",
    "REST API with token authentication for third-party integrations",
    "Docker-based deployment with Nginx, Redis, and Elasticsearch"
  ],
  "publicApiSurface": [
